{
  "name": "nohub-market",
  "private": true,
  "version": "0.1.0",
  "description": "NoHub Market — SaaS multi-tenant para mercados autônomos, conveniências e vendas online (Etapa 1)",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @nohub/db generate",
    "db:migrate": "pnpm --filter @nohub/db migrate",
    "db:push": "pnpm --filter @nohub/db push",
    "db:seed": "pnpm --filter @nohub/db seed",
    "tokens": "tsx design-system/generate-css.ts",
    "tokens:check": "tsx design-system/generate-css.ts --check",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "lefthook": "^1.10.0",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
