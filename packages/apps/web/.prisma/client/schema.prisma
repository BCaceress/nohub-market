// NoHub Market — Prisma schema
// Multi-tenant: toda entidade de domínio carrega organizationId (RN-02).
// Etapa 1: auth, multi-tenancy, onboarding, capabilities, estoque base
// Etapa 2: catálogo completo (productType, variantes, kits, preço dimensional, fiscal BR)

generator client {
  provider      = "prisma-client-js"
  output        = "../../apps/web/.prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────
// ENUMS — Etapa 1
// ─────────────────────────────────────────────────────────────────────

enum MemberRole {
  owner
  admin
  manager
  operator
  viewer
}

enum InvitationStatus {
  pending
  accepted
  expired
  revoked
}

enum DocumentType {
  CNPJ
  CPF
}

enum TaxRegime {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
  MEI
}

// Segmento operacional — define experiência, módulos, fluxos.
// RN: 1 conta = 1 segmento, imutável após onboarding.
enum SegmentType {
  BEVERAGE_CONVENIENCE // Conveniência de bebidas
  SUPERMARKET // Supermercado
  UNMANNED_MARKET // Mercado autônomo
}

// Estrutura de estoque escolhida no onboarding.
enum StockStructureType {
  LOCAL // estoque local por loja, sem CD
  CENTRAL_DC // centro de distribuição abastece lojas
  HYBRID // CD + estoque local
}

enum LocationType {
  STORE
  DC
  HYBRID
  WAREHOUSE // depósito auxiliar sem PDV
  DARK_STORE // fulfillment-only, sem atendimento presencial
}

enum SalesChannelType {
  IFOOD
  WHATSAPP
  MERCADO_LIVRE
  RAPPI
  OWN_ECOMMERCE
  OTHER
}

enum ProductUnit {
  UN // unidade
  KG // quilograma
  G // grama
  L // litro
  ML // mililitro
  CX // caixa
  PCT // pacote
  FARDO // fardo
  DZ // dúzia
  BANDEJA // bandeja
  CENTO // cento (100 unidades)
}

enum MovementType {
  // Etapa 1 (legado — mantidos por compat)
  IN
  OUT
  LOSS
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  // Etapa 3 (novos)
  INBOUND // entrada formal (compra / recebimento)
  OUTBOUND // saída por venda confirmada
  RESERVATION // reserva preventiva (anti-oversell)
  RESERVATION_RELEASE // liberação de reserva (cancelamento)
}

// ─────────────────────────────────────────────────────────────────────
// ENUMS — Etapa 3 (Estoque)
// ─────────────────────────────────────────────────────────────────────

enum MovementReason {
  PURCHASE // entrada por compra
  SALE // saída por venda
  INVENTORY_COUNT // acerto de inventário
  DAMAGE // dano/quebra
  EXPIRY // vencimento
  THEFT // furto
  TRANSFER // transferência entre locais
  MANUAL // ajuste manual com justificativa
  RETURN // devolução de cliente
  INITIAL // saldo inicial ao configurar
}

enum ReservationStatus {
  ACTIVE // reserva em aberto
  CONSUMED // convertida em OUTBOUND (pedido confirmado)
  RELEASED // cancelada (pedido cancelado/expirado)
  EXPIRED // expirou sem confirmação
}

enum InventoryCountStatus {
  DRAFT // sendo montada, itens ainda não contados
  IN_PROGRESS // contagem iniciada, operador em campo
  CLOSED // fechada — ajustes já gerados
}

// ─────────────────────────────────────────────────────────────────────
// ENUMS — Etapa 2 (Catálogo)
// ─────────────────────────────────────────────────────────────────────

enum ProductType {
  SIMPLE // produto unitário padrão
  VARIANT_PARENT // produto pai de variantes (não vendível diretamente)
  KIT // combo — sem estoque próprio, baixa componentes
  FRACTIONED // vendido por peso/volume (stockUnit ≠ saleUnit)
  CUSTOM // personalizado — componentes fixos + grupos de opção escolhidos na venda
}

// Subtipo de KIT — diferencia combo (produtos prontos, qtd inteira) de
// receita (insumos, qtd fracionada). Ambos baixam componentes na venda.
enum CompositionKind {
  COMBO // kit/combo: produtos simples vendidos juntos, quantidade inteira
  RECIPE // produzido/receita: insumos fracionados (ml, g, kg, l)
}

enum ProductBarcodeType {
  EAN13
  EAN8
  INTERNAL
  DUN14
}

// Origem do produto — tabela SEFAZ (0-8)
enum TaxOrigin {
  NACIONAL // 0
  IMPORTADO_DIRETO // 1
  IMPORTADO_NACIONAL // 2
  NACIONAL_MAIS_40_IMPORTADO // 3
  NACIONAL_MENOS_40_IMPORTADO // 4
  NACIONAL_SEM_SIMILAR // 5
  ESTRANGEIRO_DIRETO // 6
  ESTRANGEIRO_NACIONAL // 7
  NACIONAL_MENOS_70_IMPORTADO // 8
}

// Temperatura de armazenagem — perfil operacional herdável da subcategoria
enum StorageTemperature {
  AMBIENTE
  REFRIGERADO
  CONGELADO
}

enum FiscalSegment {
  BEVERAGE
  CONVENIENCE
  SNACK
  DAIRY
  BAKERY
  MEAT
  FROZEN
  CLEANING
  PERSONAL_HYGIENE
  OTHER
}

// ─────────────────────────────────────────────────────────────────────
// AUTH (Better Auth)
// ─────────────────────────────────────────────────────────────────────

model User {
  id            String  @id @default(cuid())
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String?
  phone         String?
  locale        String  @default("pt-BR")
  timezone      String  @default("America/Sao_Paulo")

  twoFactorEnabled Boolean @default(false)

  consentedAt             DateTime?
  consentVersion          String?
  dataExportRequestedAt   DateTime?
  dataDeletionRequestedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions    Session[]
  accounts    Account[]
  twoFactors  TwoFactor[]
  members     Member[]
  invitations Invitation[]     @relation("InvitedBy")
  preferences UserPreferences?
  auditLogs   AuditLog[]

  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?

  activeOrganizationId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model TwoFactor {
  id          String @id @default(cuid())
  userId      String
  secret      String
  backupCodes String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────
// TENANT
// ─────────────────────────────────────────────────────────────────────

model Organization {
  id           String       @id @default(cuid())
  slug         String       @unique
  legalName    String
  tradeName    String?
  // Document opcional no onboarding — segmento + lojas vêm primeiro; CNPJ pode ser preenchido em settings depois.
  document     String?      @unique
  documentType DocumentType @default(CNPJ)
  taxRegime    TaxRegime?

  // Segmentação operacional — definida no onboarding, imutável.
  segmentType        SegmentType?
  stockStructureType StockStructureType?

  zipCode    String?
  street     String?
  number     String?
  complement String?
  district   String?
  city       String?
  state      String?
  cnae       String?

  onboardingCompleted Boolean @default(false)
  onboardingStep      Int     @default(1)
  onboardingData      Json?

  // Financeiro — taxas de adquirente e prazo de liquidação D+N
  // { cardFeeRates: { CARD_PRESENT: number, CARD_ONLINE: number }, settlementDays: number }
  financeSettings Json?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  members                     Member[]
  invitations                 Invitation[]
  capabilities                OrganizationCapability[]
  locations                   Location[]
  salesChannels               SalesChannel[]
  suppliers                   Supplier[]
  products                    Product[]
  auditLogs                   AuditLog[]
  stockEntries                StockEntry[]
  stockMovements              StockMovement[]
  stockTransfers              StockTransfer[]
  // Etapa 2
  categories                  Category[]
  productBarcodes             ProductBarcode[]
  productVariants             ProductVariant[]
  productOptionGroups         ProductOptionGroup[]
  productPrices               ProductPrice[]
  productTaxes                ProductTax[]
  categoryTaxDefaults         CategoryTaxDefault[]
  // Etapa 3
  stockBalances               StockBalance[]
  stockLots                   StockLot[]
  stockReservations           StockReservation[]
  inventoryCounts             InventoryCount[]
  // Etapa 4
  customers                   Customer[]
  orders                      Order[]
  cashSessions                CashSession[]
  channelIntegrations         ChannelIntegration[]
  outboxEvents                OutboxEvent[]
  inboundEvents               InboundEvent[]
  // Etapa 5
  invoices                    Invoice[]
  fiscalCertificate           FiscalCertificate?
  fiscalConfig                FiscalConfig?
  invoiceNumberSkips          InvoiceNumberSkip[]
  // Etapa 6
  purchaseOrders              PurchaseOrder[]
  goodsReceipts               GoodsReceipt[]
  supplierReturns             SupplierReturn[]
  accountPayables             AccountPayable[]
  accountReceivables          AccountReceivable[]
  paymentSettlements          PaymentSettlement[]
  financeCategories           FinanceCategory[]
  quotations                  Quotation[]
  purchaseSuggestions         PurchaseSuggestion[]
  nfeImports                  NfeImport[]
  supplierProductMappings     SupplierProductMapping[]
  supplierProductPriceHistory SupplierProductPriceHistory[]
  tags                        Tag[]
  brands                      Brand[]

  @@index([document])
  @@index([deletedAt])
}

model Member {
  id             String     @id @default(cuid())
  userId         String
  organizationId String
  role           MemberRole @default(viewer)

  locationScopes String[] @default([])
  channelScopes  String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Invitation {
  id             String           @id @default(cuid())
  organizationId String
  email          String
  role           MemberRole       @default(viewer)
  status         InvitationStatus @default(pending)
  invitedById    String?
  expiresAt      DateTime
  token          String           @unique @default(cuid())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User?        @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([email])
  @@index([token])
}

model OrganizationCapability {
  id             String  @id @default(cuid())
  organizationId String
  key            String
  value          String  @default("true")
  config         Json?
  enabled        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
}

// ─────────────────────────────────────────────────────────────────────
// ESTRUTURA FÍSICA E CANAIS
// ─────────────────────────────────────────────────────────────────────

model Location {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  type           LocationType @default(STORE)
  isSelfService  Boolean      @default(false)
  is24h          Boolean      @default(false)

  zipCode    String?
  street     String?
  number     String?
  complement String?
  district   String?
  city       String?
  state      String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channelLocations    ChannelLocation[]
  stockEntries        StockEntry[]         @relation("LocationStock")
  stockMovements      StockMovement[]      @relation("LocationMovements")
  outTransfers        StockTransfer[]      @relation("TransferFrom")
  inTransfers         StockTransfer[]      @relation("TransferTo")
  // Etapa 2
  productPrices       ProductPrice[]
  // Etapa 3
  stockBalances       StockBalance[]
  stockReservations   StockReservation[]
  inventoryCounts     InventoryCount[]
  // Etapa 4
  orders              Order[]
  cashSessions        CashSession[]
  // Etapa 5
  invoices            Invoice[]
  // Etapa 6
  purchaseOrders      PurchaseOrder[]
  purchaseSuggestions PurchaseSuggestion[]

  @@index([organizationId])
}

model SalesChannel {
  id             String           @id @default(cuid())
  organizationId String
  type           SalesChannelType
  name           String
  config         Json?
  enabled        Boolean          @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channelLocations ChannelLocation[]

  @@index([organizationId])
}

model ChannelLocation {
  id              String @id @default(cuid())
  organizationId  String
  salesChannelId  String
  locationId      String
  fulfillmentRank Int    @default(0)

  createdAt DateTime @default(now())

  salesChannel SalesChannel @relation(fields: [salesChannelId], references: [id], onDelete: Cascade)
  location     Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([salesChannelId, locationId])
  @@index([organizationId])
}

model Supplier {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  tradeName      String? // nome fantasia
  document       String?
  email          String?
  phone          String?
  website        String?
  contactName    String? // pessoa de contato principal
  segment        String? // segmento/categoria (ex: bebidas, alimentos)

  // Endereço
  addressStreet     String?
  addressNumber     String?
  addressComplement String?
  addressDistrict   String?
  addressCity       String?
  addressState      String?
  addressZip        String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Condições comerciais padrão
  defaultPaymentTerms    Json? // { termsDays: Int, type: "NET"|"INSTALLMENT", installments?: [{days,percent}] }
  defaultLeadTimeDays    Int?
  minOrderAmount         Decimal? @db.Decimal(10, 2)
  deliveryDays           Json? // ["MONDAY","THURSDAY"]
  defaultDiscountPercent Decimal? @db.Decimal(5, 2)
  freightFixedAmount     Decimal? @db.Decimal(10, 2)
  freightFreeAbove       Decimal? @db.Decimal(10, 2)
  freightNotes           String?

  notes String?

  organization            Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products                Product[]
  supplierProductMappings SupplierProductMapping[]
  purchaseOrders          PurchaseOrder[]
  supplierReturns         SupplierReturn[]
  accountPayables         AccountPayable[]
  quotationResponses      QuotationSupplierResponse[]
  auditLogs               SupplierAuditLog[]

  @@index([organizationId])
}

model SupplierAuditLog {
  id             String   @id @default(cuid())
  organizationId String
  supplierId     String
  userId         String?
  userName       String?
  action         String // CREATED | UPDATED | DELETED
  changedFields  Json? // { fieldName: { from: value, to: value } }
  createdAt      DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([organizationId])
}

// ─────────────────────────────────────────────────────────────────────
// CATÁLOGO — Marcas
// ─────────────────────────────────────────────────────────────────────

model Brand {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ─────────────────────────────────────────────────────────────────────
// CATÁLOGO — Etapa 2: Categorias
// ─────────────────────────────────────────────────────────────────────

model Category {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  slug           String
  icon           String? // ID do ícone lucide (ex: "beer", "coffee")
  iconColor      String? @default("#f59e0b") // cor do ícone em hex
  parentId       String?
  position       Int     @default(0)

  hasAgeRestriction Boolean @default(false)

  // Perfil operacional herdável pela subcategoria (Category filha) → Produto
  storageTemperature StorageTemperature? // AMBIENTE | REFRIGERADO | CONGELADO
  controlsExpiry     Boolean             @default(false) // controla validade
  controlsLot        Boolean             @default(false) // controla lote

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       Category?           @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[]          @relation("CategoryTree")
  products     Product[]
  taxDefault   CategoryTaxDefault?
  defaultTags  CategoryTag[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([parentId])
}

// ─────────────────────────────────────────────────────────────────────
// CATÁLOGO — Produtos
// ─────────────────────────────────────────────────────────────────────

model Product {
  id             String  @id @default(cuid())
  organizationId String
  supplierId     String?
  categoryId     String? // FK → Category (Etapa 2)
  brandId        String? // FK → Brand

  name        String
  posName     String? // nome curto p/ PDV e cupom fiscal (≤40 chars)
  description String?
  brand       String? // legacy plain-text brand — still writable

  // SKU único por org — validado na camada de aplicação (null não computa no unique)
  sku     String?
  // Barcode legado (kept for backward compat); canônico em ProductBarcode
  barcode String?
  tags    String[] @default([])

  // Discriminador de tipo — imutável após criação (RN-C02)
  productType     ProductType      @default(SIMPLE)
  // Subtipo de KIT: COMBO (qtd inteira) ou RECIPE (insumos fracionados). null p/ não-KIT.
  compositionKind CompositionKind?

  // Unidades: stock = como o estoque conta; sale = como o cliente vê
  unit             ProductUnit @default(UN) // alias de stockUnit, mantido por compat
  saleUnit         ProductUnit @default(UN)
  conversionFactor Decimal     @default(1) @db.Decimal(10, 6)

  // Unidade de embalagem/compra (ex: FARDO) e quantas unit cabem nela (ex: 8)
  packUnit ProductUnit? // unidade maior de compra/embalagem
  packSize Int? // quantas `unit` formam 1 `packUnit`

  // Preço legado — mantido para acesso simples; canonical em ProductPrice
  price     Decimal  @default(0) @db.Decimal(10, 2)
  // 4 casas: custo de insumo granular (ex: R$/ml) usado em produto CUSTOM
  costPrice Decimal? @db.Decimal(10, 4)

  weight   Decimal? @db.Decimal(10, 3) // kg
  // Dimensões logísticas (cm) — frete e expedição
  height   Decimal? @db.Decimal(10, 2)
  width    Decimal? @db.Decimal(10, 2)
  length   Decimal? @db.Decimal(10, 2)
  imageUrl String?

  // Estoque
  stockMin   Decimal? @db.Decimal(10, 3) // ponto de reposição
  stockIdeal Decimal? @db.Decimal(10, 3) // nível alvo de reposição
  location   String? // corredor / prateleira / posição

  isActive Boolean @default(true)
  // Legado — mantido para compat com código Etapa 1
  active   Boolean @default(true)

  hasAgeRestriction Boolean @default(false)
  minAge            Int?
  allowFractioned   Boolean @default(false)

  // Overrides do perfil herdado da subcategoria — null = herda da Category
  storageTemperature StorageTemperature? // null = usa o da subcategoria
  controlsExpiry     Boolean? // null = herda; true/false = sobrescreve
  controlsLot        Boolean? // null = herda; true/false = sobrescreve

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relações Etapa 1
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier       Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  stockEntries   StockEntry[]
  stockMovements StockMovement[]
  stockTransfers StockTransfer[]

  // Relações Etapa 2
  category                Category?                @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brandRef                Brand?                   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  barcodes                ProductBarcode[]
  variants                ProductVariant[]
  kitComponents           ProductKitComponent[]    @relation("KitProduct")
  asComponent             ProductKitComponent[]    @relation("ComponentProduct")
  // CUSTOM — grupos de opção (deste produto) e uso como insumo de opção
  optionGroups            ProductOptionGroup[]
  asOption                ProductOption[]          @relation("OptionComponentProduct")
  prices                  ProductPrice[]
  taxData                 ProductTax[]
  // Relações Etapa 3
  stockBalances           StockBalance[]
  stockLots               StockLot[]
  stockReservations       StockReservation[]
  inventoryCountItems     InventoryCountItem[]
  // Relações Etapa 6
  purchaseOrderItems      PurchaseOrderItem[]
  goodsReceiptItems       GoodsReceiptItem[]
  supplierProductMappings SupplierProductMapping[]
  quotationItems          QuotationItem[]
  purchaseSuggestionItems PurchaseSuggestionItem[]
  productTags             ProductTag[]

  @@index([organizationId])
  @@index([supplierId])
  @@index([categoryId])
  @@index([barcode])
  @@index([organizationId, isActive])
  @@index([organizationId, productType])
}

// Múltiplos códigos de barras por produto (caixa, fardo, unidade)
model ProductBarcode {
  id             String             @id @default(cuid())
  organizationId String
  productId      String
  variantId      String?
  barcode        String
  type           ProductBarcodeType @default(EAN13)

  // Multi-embalagem: nome da embalagem ("Unidade", "Fardo 6", "Caixa 24")
  // e quantas `unit` cada bipada representa (1, 6, 24).
  label     String? // exibido no PDV / cadastro
  factor    Decimal @default(1) @db.Decimal(10, 3) // multiplicador de quantidade
  isDefault Boolean @default(false)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([organizationId, barcode])
  @@index([organizationId])
  @@index([productId])
}

// Variantes de um VARIANT_PARENT (ex: Coca 350ml, 600ml, 2L)
model ProductVariant {
  id             String  @id @default(cuid())
  organizationId String
  productId      String
  name           String // ex: "350ml", "P", "Morango"
  sku            String?
  attributes     Json    @default("{}") // {"volume":"350ml","flavor":"cola"}
  isActive       Boolean @default(true)
  position       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product                 Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)
  barcodes                ProductBarcode[]
  prices                  ProductPrice[]
  taxData                 ProductTax[]
  asComponent             ProductKitComponent[]    @relation("ComponentVariant")
  asOption                ProductOption[]          @relation("OptionComponentVariant")
  // Etapa 3
  stockMovements          StockMovement[]          @relation("VariantMovements")
  stockBalances           StockBalance[]
  stockLots               StockLot[]
  stockReservations       StockReservation[]
  // Etapa 6
  purchaseOrderItems      PurchaseOrderItem[]
  goodsReceiptItems       GoodsReceiptItem[]
  supplierProductMappings SupplierProductMapping[]
  quotationItems          QuotationItem[]
  purchaseSuggestionItems PurchaseSuggestionItem[]

  @@index([organizationId])
  @@index([productId])
}

// Composição de um KIT — componentes não podem ser KIT (RN-C04)
model ProductKitComponent {
  id                 String   @id @default(cuid())
  kitProductId       String
  componentProductId String
  componentVariantId String?
  quantity           Decimal  @db.Decimal(10, 3)
  position           Int      @default(0)
  createdAt          DateTime @default(now())

  kitProduct       Product         @relation("KitProduct", fields: [kitProductId], references: [id], onDelete: Cascade)
  componentProduct Product         @relation("ComponentProduct", fields: [componentProductId], references: [id])
  componentVariant ProductVariant? @relation("ComponentVariant", fields: [componentVariantId], references: [id])

  @@unique([kitProductId, componentProductId, componentVariantId])
  @@index([kitProductId])
  @@index([componentProductId])
}

// ─────────────────────────────────────────────────────────────────────
// CATÁLOGO — Produto CUSTOM (personalizado)
// Itens fixos reaproveitam ProductKitComponent. Grupos de opção abaixo
// são as escolhas montadas no momento da venda (ex: "Escolha da Vodka").
// ─────────────────────────────────────────────────────────────────────

// Grupo de escolha de um produto CUSTOM (radio se maxSelect=1, checkbox se >1)
model ProductOptionGroup {
  id             String      @id @default(cuid())
  organizationId String
  productId      String
  name           String // "Escolha da Vodka"
  unit           ProductUnit @default(UN) // unidade das quantidades das opções (ml, un…)
  required       Boolean     @default(true)
  minSelect      Int         @default(1) // mínimo de opções a escolher
  maxSelect      Int         @default(1) // máximo (1 = exclusivo)
  position       Int         @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  options      ProductOption[]

  @@index([organizationId])
  @@index([productId])
}

// Opção de um grupo — aponta para Product/Variant real (estoque/custo/fiscal)
model ProductOption {
  id                 String  @id @default(cuid())
  groupId            String
  componentProductId String
  componentVariantId String?
  name               String // rótulo exibido (default = nome do componente)
  quantity           Decimal @default(1) @db.Decimal(10, 3) // quanto baixa do insumo
  priceDelta         Decimal @default(0) @db.Decimal(10, 2) // acréscimo no preço
  isDefault          Boolean @default(false)
  position           Int     @default(0)

  createdAt DateTime @default(now())

  group            ProductOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  componentProduct Product            @relation("OptionComponentProduct", fields: [componentProductId], references: [id])
  componentVariant ProductVariant?    @relation("OptionComponentVariant", fields: [componentVariantId], references: [id])

  @@index([groupId])
  @@index([componentProductId])
}

// Preço dimensional: produto × variante × location × canal
// Resolução em cascata: mais específico → menos específico (RN-C08)
model ProductPrice {
  id             String            @id @default(cuid())
  organizationId String
  productId      String
  variantId      String?
  locationId     String?
  channel        SalesChannelType?

  price      Decimal  @db.Decimal(10, 2)
  promoPrice Decimal? @db.Decimal(10, 2)
  cost       Decimal? @db.Decimal(10, 2)

  // Janela de promoção — promoPrice só vale dentro deste intervalo (RN-C09)
  validFrom DateTime?
  validTo   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  location     Location?       @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([productId, variantId])
  @@index([locationId, channel])
  @@index([validFrom, validTo])
}

// ─────────────────────────────────────────────────────────────────────
// FISCAL — NCM / CEST / CFOP / CST / CSOSN
// CST: regime Normal; CSOSN: Simples Nacional — nunca os dois (RN-C06)
// Campos CST/CSOSN são String para não exigir enum gigante — validados via Zod
// ─────────────────────────────────────────────────────────────────────

model ProductTax {
  id             String  @id @default(cuid())
  organizationId String
  productId      String
  variantId      String?

  ncm            String // 8 dígitos (RN-C07)
  cest           String? // 7 dígitos (RN-C07)
  cfopInternal   String? // operações internas  ex: "5102"
  cfopInterstate String? // operações interestaduais ex: "6102"

  origin TaxOrigin @default(NACIONAL)

  // ICMS — use CST (Normal) OU CSOSN (Simples) conforme taxRegime da org
  icmsCst   String? // "00","10","20","30","40","41","50","51","60","70","90"
  icmsCsosn String? // "101","102","103","201","202","203","300","400","500","900"
  icmsRate  Decimal? @db.Decimal(5, 2)

  // PIS
  pisCst  String? // "01"-"09","49","50","99"
  pisRate Decimal? @db.Decimal(5, 4)

  // COFINS
  cofinsCst  String?
  cofinsRate Decimal? @db.Decimal(5, 4)

  // IPI
  ipiCst  String?
  ipiRate Decimal? @db.Decimal(5, 2)

  unitTaxable Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([productId, variantId])
  @@index([organizationId])
  @@index([productId])
}

// Fiscal padrão por categoria — herança (RN-C13)
model CategoryTaxDefault {
  id             String @id @default(cuid())
  organizationId String
  categoryId     String @unique

  ncm            String?
  cest           String?
  cfopInternal   String?
  cfopInterstate String?
  origin         TaxOrigin @default(NACIONAL)
  icmsCst        String?
  icmsCsosn      String?
  icmsRate       Decimal?  @db.Decimal(5, 2)
  pisCst         String?
  pisRate        Decimal?  @db.Decimal(5, 4)
  cofinsCst      String?
  cofinsRate     Decimal?  @db.Decimal(5, 4)
  ipiCst         String?
  ipiRate        Decimal?  @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// Templates fiscais globais — pré-populados por segmento (diferencial competitivo)
// Tabela GLOBAL (não por tenant) — seed em seed-fiscal.ts
model FiscalTemplate {
  id          String        @id @default(cuid())
  segment     FiscalSegment
  productName String
  barcode     String? // EAN13 canônico para lookup automático

  suggestedNcm          String
  suggestedCest         String?
  defaultCfopInternal   String  @default("5102")
  defaultCfopInterstate String  @default("6102")

  icmsCst   String?
  icmsCsosn String?
  pisCst    String?   @default("01")
  cofinsCst String?   @default("01")
  origin    TaxOrigin @default(NACIONAL)

  description String? // nome técnico / observação para o operador

  createdAt DateTime @default(now())

  @@index([segment])
  @@index([barcode])
  @@index([suggestedNcm])
}

// ─────────────────────────────────────────────────────────────────────
// GESTÃO DE ESTOQUE (Etapa 1 — sem alterações)
// ─────────────────────────────────────────────────────────────────────

model StockEntry {
  id             String @id @default(cuid())
  organizationId String
  locationId     String
  productId      String

  quantity      Decimal   @default(0) @db.Decimal(10, 3)
  minQuantity   Decimal?  @db.Decimal(10, 3)
  maxQuantity   Decimal?  @db.Decimal(10, 3)
  shelfLocation String?
  expiryDate    DateTime?
  batchCode     String?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location     @relation("LocationStock", fields: [locationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([locationId, productId])
  @@index([organizationId])
  @@index([locationId])
  @@index([productId])
  @@index([expiryDate])
  @@index([organizationId, quantity])
}

model StockMovement {
  id             String @id @default(cuid())
  organizationId String
  locationId     String
  productId      String

  type        MovementType
  quantity    Decimal      @db.Decimal(10, 3)
  previousQty Decimal      @db.Decimal(10, 3)
  newQty      Decimal      @db.Decimal(10, 3)
  transferId  String? // legado Etapa 1
  notes       String? // legado Etapa 1
  userId      String
  userName    String?

  // Etapa 3 — campos adicionais (todos nullable para compat)
  variantId       String? // FK → ProductVariant
  lotId           String? // FK → StockLot
  unitCost        Decimal?        @db.Decimal(10, 4) // custo unitário nesta entrada
  reason          MovementReason? // motivo estruturado
  referenceType   String? // "ORDER" | "PURCHASE" | "TRANSFER" ...
  referenceId     String? // ID da entidade que originou o movimento
  transferGroupId String? // par TRANSFER_OUT+IN — mesmo grupo
  idempotencyKey  String? // retry-safe (único por org quando presente)
  note            String? // alias mais limpo para notes (Etapa 3)

  createdAt DateTime @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location        @relation("LocationMovements", fields: [locationId], references: [id], onDelete: SetNull)
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant      ProductVariant? @relation("VariantMovements", fields: [variantId], references: [id], onDelete: SetNull)
  lot          StockLot?       @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId])
  @@index([locationId])
  @@index([productId])
  @@index([variantId])
  @@index([lotId])
  @@index([type])
  @@index([reason])
  @@index([transferGroupId])
  @@index([createdAt])
  @@index([organizationId, createdAt])
  @@index([referenceType, referenceId])
}

model StockTransfer {
  id             String @id @default(cuid())
  organizationId String
  fromLocationId String
  toLocationId   String
  productId      String

  quantity Decimal @db.Decimal(10, 3)
  notes    String?
  status   String  @default("completed")
  userId   String
  userName String?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromLocation Location     @relation("TransferFrom", fields: [fromLocationId], references: [id])
  toLocation   Location     @relation("TransferTo", fields: [toLocationId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])

  @@index([organizationId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────────────
// GESTÃO DE ESTOQUE — Etapa 3 (saldo, lote, reserva, inventário)
// ─────────────────────────────────────────────────────────────────────

// Lote/validade — só criado quando capability product.expiry_tracking (RN-E05)
model StockLot {
  id              String    @id @default(cuid())
  organizationId  String
  productId       String
  variantId       String?
  code            String // código do lote (fornecedor ou gerado)
  expiryDate      DateTime?
  manufactureDate DateTime?
  receivedAt      DateTime  @default(now())
  isActive        Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant      ProductVariant?    @relation(fields: [variantId], references: [id], onDelete: SetNull)
  movements    StockMovement[]
  balances     StockBalance[]
  reservations StockReservation[]

  @@unique([organizationId, productId, code])
  @@index([organizationId])
  @@index([productId])
  @@index([expiryDate])
  @@index([isActive])
}

// Saldo materializado — projeção reconstruível a partir dos movimentos (RN-E03)
// Saldo NUNCA é editado diretamente — atualizado apenas via applyMovement (RN-E01)
model StockBalance {
  id             String  @id @default(cuid())
  organizationId String
  productId      String
  variantId      String?
  locationId     String
  lotId          String?

  quantityOnHand   Decimal @default(0) @db.Decimal(10, 3) // físico
  quantityReserved Decimal @default(0) @db.Decimal(10, 3) // reservado
  // quantityAvailable = quantityOnHand - quantityReserved (calculada na query)

  averageCost   Decimal? @db.Decimal(10, 4) // custo médio móvel (RN-E09)
  minQuantity   Decimal? @db.Decimal(10, 3) // limiar de alerta / ponto de reposição
  idealQuantity Decimal? @db.Decimal(10, 3) // quantidade alvo após reposição

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  location     Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  lot          StockLot?       @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@unique([organizationId, productId, variantId, locationId, lotId])
  @@index([organizationId])
  @@index([productId, variantId])
  @@index([locationId])
  @@index([lotId])
  @@index([organizationId, quantityOnHand])
}

// Reserva ativa — espelha movimentos de RESERVATION (anti-oversell RN-E07)
model StockReservation {
  id             String  @id @default(cuid())
  organizationId String
  productId      String
  variantId      String?
  locationId     String
  lotId          String?

  quantity      Decimal           @db.Decimal(10, 3)
  referenceType String // "ORDER", "CART", etc.
  referenceId   String // ID do pedido/carrinho
  status        ReservationStatus @default(ACTIVE)
  expiresAt     DateTime? // null = sem expiração automática

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  location     Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  lot          StockLot?       @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([productId, variantId, locationId])
  @@index([referenceType, referenceId])
  @@index([status])
  @@index([expiresAt])
}

// Sessão de contagem/inventário físico
model InventoryCount {
  id             String               @id @default(cuid())
  organizationId String
  locationId     String
  status         InventoryCountStatus @default(DRAFT)
  startedBy      String // userId
  note           String?

  startedAt DateTime  @default(now())
  closedAt  DateTime?

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location             @relation(fields: [locationId], references: [id], onDelete: Cascade)
  items        InventoryCountItem[]

  @@index([organizationId])
  @@index([locationId])
  @@index([status])
}

// Item contado em uma sessão de inventário
model InventoryCountItem {
  id        String  @id @default(cuid())
  countId   String
  productId String
  variantId String?
  lotId     String?

  systemQuantity  Decimal  @db.Decimal(10, 3) // saldo no sistema no momento
  countedQuantity Decimal? @db.Decimal(10, 3) // contado fisicamente (null = não contado)
  // divergence = countedQuantity - systemQuantity (calculada)

  adjustmentMovementId String? // movimento de acerto gerado ao fechar (RN-E13)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  count   InventoryCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])

  @@unique([countId, productId, variantId, lotId])
  @@index([countId])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────────────
// PREFERÊNCIAS E AUDITORIA
// ─────────────────────────────────────────────────────────────────────

model UserPreferences {
  id     String @id @default(cuid())
  userId String @unique

  activeScopeType String?
  activeScopeId   String?
  theme           String  @default("system")
  locale          String  @default("pt-BR")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String  @id @default(cuid())
  organizationId String?
  actorId        String?
  action         String
  resourceType   String
  resourceId     String?
  before         Json?
  after          Json?
  metadata       Json?
  ipAddress      String?

  createdAt DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor        User?         @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([actorId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────
// ENUMS — Etapa 4 (Vendas + Canais + Pagamento)
// ─────────────────────────────────────────────────────────────────────

enum OrderChannel {
  POS // PDV operado (caixa)
  SELF_SERVICE // autônomo / kiosk
  IFOOD
  WHATSAPP
  MERCADO_LIVRE
}

enum OrderStatus {
  DRAFT // carrinho aberto / comanda
  CONFIRMED // confirmado, estoque reservado
  PAID // pagamento confirmado
  FULFILLED // separado / expedido
  COMPLETED // entregue / concluído
  CANCELED // cancelado (imutável)
}

enum PaymentMethod {
  CASH // dinheiro
  PIX_MANUAL // Pix sem QR (manual)
  PIX_DYNAMIC // Pix QR dinâmico (webhook adquirente)
  CARD_PRESENT // cartão presente (maquininha) — legado/genérico
  CARD_CREDIT // cartão de crédito (maquininha)
  CARD_DEBIT // cartão de débito (maquininha)
  CARD_ONLINE // cartão online (tokenizado)
  VOUCHER // vale / crédito interno
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REFUNDED
  FAILED
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  OPEN // abertura
  CLOSE // fechamento
  BLEED // sangria
  SUPPLY // suprimento
}

enum ChannelStatus {
  DISCONNECTED
  CONNECTED
  ERROR
}

enum OutboxStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
  DEAD
}

enum MlLogisticMode {
  FULL // estoque e entrega ML
  FLEX // entrega própria, MarketOS faz fulfillment
  CLASSIC // retira ou entrega por conta
}

// ─────────────────────────────────────────────────────────────────────
// VENDAS — Etapa 4
// ─────────────────────────────────────────────────────────────────────

// Cliente identificado (obrigatório em SELF_SERVICE — RN-V14)
model Customer {
  id             String  @id @default(cuid())
  organizationId String
  personType     String  @default("PF") // PF | PJ
  name           String?
  document       String? // CPF/CNPJ (PII)
  phone          String? // (PII)
  whatsapp       String? // (PII)
  email          String? // (PII)
  contactName    String? // pessoa de contato (PJ)

  // Endereço
  addressStreet     String?
  addressNumber     String?
  addressComplement String?
  addressDistrict   String?
  addressCity       String?
  addressState      String?
  addressZip        String?

  notes String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders       Order[]
  invoices     Invoice[] // Etapa 5
  receivables  AccountReceivable[]
  auditLogs    CustomerAuditLog[]

  @@index([organizationId])
  @@index([organizationId, document])
  @@index([organizationId, phone])
}

model CustomerAuditLog {
  id             String   @id @default(cuid())
  organizationId String
  customerId     String
  userId         String?
  userName       String?
  action         String // CREATED | UPDATED | DELETED | REACTIVATED | DEACTIVATED
  changedFields  Json? // { fieldName: { from: value, to: value } }
  createdAt      DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([organizationId])
}

// Pedido — agregador genérico; canal é adapter (RN-V01)
model Order {
  id             String       @id @default(cuid())
  organizationId String
  locationId     String
  channel        OrderChannel
  status         OrderStatus  @default(DRAFT)
  customerId     String?
  cashSessionId  String?

  subtotal      Decimal @default(0) @db.Decimal(10, 2)
  discountTotal Decimal @default(0) @db.Decimal(10, 2)
  total         Decimal @default(0) @db.Decimal(10, 2)

  // Idempotência dupla (RN-V09)
  idempotencyKey String? // interno — @@unique abaixo
  externalId     String? // id do pedido no canal externo

  // Dados específicos do canal (endereço entrega, etc.)
  channelMetadata Json?

  canceledReason String?
  canceledAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location      Location             @relation(fields: [locationId], references: [id])
  customer      Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  cashSession   CashSession?         @relation(fields: [cashSessionId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  payments      Payment[]
  receivables   AccountReceivable[]
  invoice       Invoice? // Etapa 5

  // NULL values in PG unique constraints are treated as distinct — múltiplos NULLs OK
  @@unique([organizationId, channel, externalId])
  @@unique([organizationId, idempotencyKey])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, channel])
  @@index([locationId])
  @@index([customerId])
  @@index([cashSessionId])
  @@index([createdAt])
}

// Item de pedido — SNAPSHOT imutável (RN-V03)
model OrderItem {
  id      String @id @default(cuid())
  orderId String

  // Referência fraca ao produto (para relatórios)
  productId String?
  variantId String?

  // SNAPSHOT congelado no momento da venda
  productNameSnapshot String
  skuSnapshot         String?
  unitSnapshot        String?
  unitPriceSnapshot   Decimal  @db.Decimal(10, 2)
  costSnapshot        Decimal? @db.Decimal(10, 4)
  taxSnapshot         Json? // {ncm, cst, pisCst, cofinsRate, ...}
  productTypeSnapshot String   @default("SIMPLE")

  quantity       Decimal @db.Decimal(10, 3)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  lineTotal      Decimal @db.Decimal(10, 2)

  isKit Boolean @default(false) // true = componentes explodidos no estoque (RN-V10)

  createdAt DateTime @default(now())

  order      Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  selections OrderItemSelection[]

  @@index([orderId])
  @@index([productId])
}

// Escolha feita num item CUSTOM no momento da venda — snapshot congelado.
// Dirige a baixa de estoque dos insumos escolhidos no fulfillOrder.
model OrderItemSelection {
  id          String @id @default(cuid())
  orderItemId String

  // Referências fracas (relatório "qual opção mais vende")
  groupId            String?
  optionId           String?
  componentProductId String?
  componentVariantId String?

  // SNAPSHOT congelado
  groupNameSnapshot  String
  optionNameSnapshot String
  quantitySnapshot   Decimal @default(1) @db.Decimal(10, 3)
  priceDeltaSnapshot Decimal @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@index([componentProductId])
}

// Histórico imutável de transições de estado
model OrderStatusHistory {
  id         String       @id @default(cuid())
  orderId    String
  fromStatus OrderStatus?
  toStatus   OrderStatus
  actorId    String?
  source     String       @default("INTERNAL") // INTERNAL/IFOOD/ML/WHATSAPP/PAYMENT
  reason     String?

  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

// Pagamento — via adapter de adquirente (RN-V11)
model Payment {
  id      String @id @default(cuid())
  orderId String

  method            PaymentMethod
  provider          String? // "pagarme" | "stone" | "mercadopago"
  amount            Decimal       @db.Decimal(10, 2)
  receivedAmount    Decimal?      @db.Decimal(10, 2) // dinheiro recebido
  changeAmount      Decimal?      @db.Decimal(10, 2) // troco
  status            PaymentStatus @default(PENDING)
  externalPaymentId String? // id na adquirente
  pixQrCode         String? // QR copia-e-cola
  pixQrCodeUrl      String? // QR imagem (data URL)
  pixExpiresAt      DateTime?

  confirmedAt DateTime?
  failedAt    DateTime?
  refundedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order      Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  settlement PaymentSettlement?

  @@index([orderId])
  @@index([status])
  @@index([externalPaymentId])
}

// Sessão de caixa (só POS — RN-V14)
model CashSession {
  id             String            @id @default(cuid())
  organizationId String
  locationId     String
  operatorId     String // userId
  status         CashSessionStatus @default(OPEN)

  openingAmount Decimal  @db.Decimal(10, 2) // fundo de troco
  closingAmount Decimal? @db.Decimal(10, 2) // informado no fechamento
  systemAmount  Decimal? @db.Decimal(10, 2) // calculado pelo sistema
  divergence    Decimal? @db.Decimal(10, 2) // closingAmount - systemAmount

  openedAt DateTime  @default(now())
  closedAt DateTime?
  note     String?

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location       @relation(fields: [locationId], references: [id])
  movements    CashMovement[]
  orders       Order[]

  @@index([organizationId])
  @@index([locationId])
  @@index([status])
  @@index([operatorId])
}

// Sangria / suprimento / abertura / fechamento
model CashMovement {
  id            String           @id @default(cuid())
  cashSessionId String
  type          CashMovementType
  amount        Decimal          @db.Decimal(10, 2)
  note          String?
  actorId       String?
  categoryId    String?

  createdAt DateTime @default(now())

  cashSession CashSession      @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)
  category    FinanceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([cashSessionId])
  @@index([categoryId])
}

// ─────────────────────────────────────────────────────────────────────
// INTEGRAÇÃO DE CANAIS — Etapa 4
// ─────────────────────────────────────────────────────────────────────

// Configuração e credenciais de canal por organização
model ChannelIntegration {
  id             String       @id @default(cuid())
  organizationId String
  channel        OrderChannel // IFOOD | WHATSAPP | MERCADO_LIVRE

  status       ChannelStatus @default(DISCONNECTED)
  credentials  Json? // access_token, refresh_token, expiresAt — cifrado em prod
  settings     Json? // {mlLogisticMode, whatsappNumber, ifoodMerchantId, ...}
  lastSyncAt   DateTime?
  lastErrorAt  DateTime?
  lastErrorMsg String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization    Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productMappings ChannelProductMapping[]

  @@unique([organizationId, channel])
  @@index([organizationId])
  @@index([status])
}

// Mapeamento produto MarketOS ↔ id externo por canal
model ChannelProductMapping {
  id                   String       @id @default(cuid())
  channelIntegrationId String
  organizationId       String
  productId            String
  variantId            String?
  channel              OrderChannel
  externalId           String // id no iFood/ML/WhatsApp
  externalSku          String?
  syncedAt             DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channelIntegration ChannelIntegration @relation(fields: [channelIntegrationId], references: [id], onDelete: Cascade)

  @@unique([channelIntegrationId, productId, variantId])
  @@unique([channelIntegrationId, externalId])
  @@index([organizationId])
  @@index([channel, externalId])
}

// ─────────────────────────────────────────────────────────────────────
// OUTBOX — Etapa 4 (resiliência a terceiro fora do ar — RN-V06)
// ─────────────────────────────────────────────────────────────────────

// Eventos a enviar para canais externos — processados com retry
model OutboxEvent {
  id             String       @id @default(cuid())
  organizationId String
  aggregateType  String // "Order" | "Payment" | "ChannelIntegration"
  aggregateId    String // id do agregado
  eventType      String // "ORDER_CONFIRMED" | "PUSH_STATUS_IFOOD" | "SYNC_CATALOG"
  payload        Json
  status         OutboxStatus @default(PENDING)
  priority       Int          @default(0) // maior = mais prioritário; 10 = SLA iFood (RN-V07)
  attempts       Int          @default(0)
  maxAttempts    Int          @default(5)
  nextRetryAt    DateTime?
  processedAt    DateTime?
  lastError      String?
  idempotencyKey String       @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status, nextRetryAt])
  @@index([status, priority])
  @@index([aggregateType, aggregateId])
  @@index([createdAt])
}

// Eventos recebidos de canais (webhook/polling) — idempotência
model InboundEvent {
  id              String       @id @default(cuid())
  organizationId  String
  channel         OrderChannel
  externalEventId String // id único no canal externo
  eventType       String?
  payload         Json
  processedAt     DateTime?
  errorMsg        String?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([channel, externalEventId])
  @@index([organizationId])
  @@index([channel])
  @@index([processedAt])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────
// FISCAL — Etapa 5 (NFCe via BaaS — RN-F01)
// ─────────────────────────────────────────────────────────────────────

enum InvoiceType {
  NFCE // Nota Fiscal de Consumidor Eletrônica
  // NFE // futura etapa (B2B)
}

enum InvoiceStatus {
  PENDING // aguardando worker
  SENDING // enviado ao BaaS/SEFAZ, aguardando resposta
  IN_CONTINGENCY // SEFAZ fora; cupom emitido localmente (EPEC/SVC)
  AUTHORIZED // autorizada pela SEFAZ
  REJECTED // rejeitada pela SEFAZ (reemitível após correção)
  DENIED // denegada pela SEFAZ (não reemitível com mesmos dados)
  CANCELED // cancelada dentro do prazo (terminal)
}

enum InvoiceEventType {
  SUBMITTED // enviada ao BaaS
  AUTHORIZED // autorizada pela SEFAZ
  REJECTED // rejeitada
  DENIED // denegada
  CONTINGENCY_ENTERED // entrou em contingência
  CONTINGENCY_TRANSMITTED // transmitida após SEFAZ voltar
  CANCEL_REQUESTED // cancelamento solicitado
  CANCELED // cancelada
  INUTILIZED // número inutilizado (InvoiceNumberSkip)
  RETRY_SCHEDULED // retry agendado
}

enum InvoiceEventSource {
  INTERNAL // ação da lib interna
  WORKER // disparado pelo worker do Outbox
  PROVIDER_WEBHOOK // webhook do BaaS (Focus/TecnoSpeed)
  MANUAL // ação manual de admin
}

enum FiscalEnvironment {
  HOMOLOGATION // sandbox do BaaS — notas sem validade fiscal
  PRODUCTION // produção real — notas com validade fiscal
}

enum FiscalProviderEnum {
  FOCUS_NFE // Focus NFe (Acras Tecnologia)
  TECNOSPEED // TecnoSpeed
}

enum ContingencyMode {
  EPEC // Emissão em Contingência via EPEC
  SVC // Sefaz Virtual de Contingência
}

enum NumberSkipStatus {
  REQUESTED // solicitação criada
  INUTILIZED // inutilizada com sucesso
  REJECTED // rejeitada pelo BaaS/SEFAZ
}

// Nota fiscal eletrônica (NFCe) — uma por pedido (RN-F03)
model Invoice {
  id             String  @id @default(cuid())
  organizationId String
  locationId     String
  orderId        String  @unique // uma nota por pedido — idempotência (RN-F03)
  customerId     String?

  type   InvoiceType   @default(NFCE)
  status InvoiceStatus @default(PENDING)

  // Numeração SEFAZ (atribuída na autorização)
  series Int  @default(1)
  number Int? // número sequencial do BaaS/SEFAZ

  // Chaves de autorização
  accessKey String? // chave 44 dígitos
  protocol  String? // protocolo de autorização SEFAZ

  // Timestamps de lifecycle
  issuedAt     DateTime?
  authorizedAt DateTime?
  canceledAt   DateTime?

  // Valores fiscais
  totalAmount Decimal @default(0) @db.Decimal(10, 2)
  totalTax    Decimal @default(0) @db.Decimal(10, 2)

  // BaaS
  provider          FiscalProviderEnum
  providerInvoiceId String? // id no BaaS — único por provider+org
  xmlIssued         String?            @db.Text // XML autorizado (≤ 512KB)
  xmlCanceled       String?            @db.Text // XML de cancelamento
  qrCode            String? // URL/payload do QR Code
  danfeUrl          String? // URL do DANFE/PDF

  // Rejeição
  rejectionReason String?
  rejectionCode   String? // código SEFAZ (ex: "539", "999")

  // Cancelamento
  cancelReason   String?
  cancelDeadline DateTime? // prazo para cancelar (calculado de authorizedAt)

  // Contingência
  contingencyMode ContingencyMode?

  // Idempotência + retry
  idempotencyKey String    @unique // geralmente orderId
  attemptCount   Int       @default(0)
  lastAttemptAt  DateTime?
  nextRetryAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location       @relation(fields: [locationId], references: [id])
  order        Order          @relation(fields: [orderId], references: [id])
  customer     Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  events       InvoiceEvent[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, accessKey])
  @@index([organizationId, number])
  @@index([provider, providerInvoiceId])
  @@index([createdAt])
}

// Trilha imutável de eventos — evidência legal (RN-F16)
model InvoiceEvent {
  id               String             @id @default(cuid())
  invoiceId        String
  eventType        InvoiceEventType
  fromStatus       InvoiceStatus?
  toStatus         InvoiceStatus
  actorId          String? // null = sistema/webhook
  source           InvoiceEventSource @default(INTERNAL)
  providerResponse Json? // payload bruto do BaaS (auditoria, nunca expor na UI padrão)
  note             String?

  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([createdAt])
}

// Certificado A1 do cliente — cifrado (RN-F08)
model FiscalCertificate {
  id             String @id @default(cuid())
  organizationId String @unique // um certificado ativo por org

  subject           String // CNPJ do titular do certificado
  validFrom         DateTime
  validTo           DateTime
  encryptedPfx      Bytes // .pfx cifrado (AES-256-GCM)
  encryptedPassword Bytes // senha cifrada
  iv                Bytes // IV da cifra (salvo junto)

  isActive   Boolean   @default(true)
  uploadedBy String // userId de quem fez upload
  uploadedAt DateTime  @default(now())
  revokedAt  DateTime?
  revokedBy  String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// Configuração fiscal por organização
model FiscalConfig {
  id             String @id @default(cuid())
  organizationId String @unique

  environment FiscalEnvironment  @default(HOMOLOGATION)
  provider    FiscalProviderEnum @default(FOCUS_NFE)

  // NFCe
  nfceSeries   Int     @default(1)
  nfceCscId    String? // ID do CSC (Código de Segurança do Contribuinte)
  nfceCscToken Bytes? // CSC cifrado

  // Credenciais do BaaS — cifradas
  providerCredentials Bytes? // JSON cifrado {token, cnpj, ...}

  // Estado da configuração
  homologationTestedAt DateTime? // quando emitiu com sucesso em homologação
  promotedAt           DateTime? // quando promoveu para produção

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// Inutilização de numeração — compliance SEFAZ (RN-F15)
model InvoiceNumberSkip {
  id               String           @id @default(cuid())
  organizationId   String
  series           Int
  numberStart      Int
  numberEnd        Int
  reason           String
  status           NumberSkipStatus @default(REQUESTED)
  requestedBy      String // userId
  requestedAt      DateTime         @default(now())
  processedAt      DateTime?
  providerResponse Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, series])
}

// ─────────────────────────────────────────────────────────────────────
// COMPRAS — Etapa 6
// ─────────────────────────────────────────────────────────────────────

enum PurchaseOrderStatus {
  DRAFT // rascunho — em elaboração
  SENT // enviado ao fornecedor
  CONFIRMED // fornecedor confirmou prazo/condições
  RECEIVING // recebimento parcial em andamento
  RECEIVED // todo o pedido recebido
  CANCELED // cancelado
}

enum GoodsReceiptStatus {
  DRAFT // em conferência — operador pode ajustar
  CONFIRMED // conferência encerrada; estoque atualizado
  CANCELED
}

enum SupplierReturnStatus {
  DRAFT
  CONFIRMED
  CANCELED
}

enum SupplierReturnReason {
  DEFECT // defeito / avaria
  EXPIRY // vencido / próximo do vencimento
  WRONG_ITEM // item errado entregue
  OVERSTOCK // excesso de estoque
  OTHER
}

enum DivergenceType {
  NONE // sem divergência
  QUANTITY // quantidade diverge do PO
  COST // custo diverge do PO
  QUALITY // problema de qualidade
}

enum AccountPayableStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  CANCELED
}

enum QuotationStatus {
  OPEN // aguardando respostas
  CLOSED // encerrada sem converter
  CONVERTED // convertida em PO
}

enum PurchaseSuggestionStatus {
  PENDING // aguardando revisão do usuário
  CONVERTED // convertida em PO
  DISMISSED // descartada
}

enum NfeImportStatus {
  PENDING // XML recebido, aguardando parse
  PARSED // parser OK, aguardando mapping
  MAPPED // todos os itens mapeados
  CONFIRMED // PO + recebimento criados
  REJECTED // falha no parse ou validação
}

enum PoHistorySource {
  INTERNAL
  XML_IMPORT
  MANUAL
}

// ── Mapeamento de catálogo fornecedor <-> produto MarketOS (RN-P12) ───

model SupplierProductMapping {
  id             String @id @default(cuid())
  organizationId String
  supplierId     String

  supplierProductCode String
  supplierProductName String

  productId String
  variantId String?

  // ── Condições comerciais do fornecedor para este produto ──────────
  defaultPackQuantity Decimal?     @db.Decimal(10, 3) // quantas `unit` por embalagem de compra
  purchaseUnit        ProductUnit? // unidade comprada (CX, FARDO, PCT…)
  minOrderQuantity    Decimal?     @db.Decimal(10, 3) // pedido mínimo (em purchaseUnit)
  barcode             String? // EAN/código de barras próprio do fornecedor
  leadTimeDays        Int? // prazo de entrega — override de Supplier.defaultLeadTimeDays
  discountPercent     Decimal?     @db.Decimal(5, 2) // desconto negociado (%)

  // ── Custos (snapshot; série completa em SupplierProductPriceHistory) ─
  lastCost       Decimal?  @db.Decimal(10, 4) // preço de compra atual
  previousCost   Decimal?  @db.Decimal(10, 4) // preço de compra anterior
  lastPurchaseAt DateTime? // data da última compra deste produto neste fornecedor

  // ── Status ────────────────────────────────────────────────────────
  isPreferred Boolean @default(false) // fornecedor preferencial para este produto
  active      Boolean @default(true) // desativa sem apagar histórico

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier     Supplier                      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product      Product                       @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant      ProductVariant?               @relation(fields: [variantId], references: [id], onDelete: SetNull)
  priceHistory SupplierProductPriceHistory[]

  @@unique([supplierId, supplierProductCode])
  @@index([organizationId])
  @@index([productId])
  @@index([productId, isPreferred])
}

// ── Histórico de preço de compra por mapeamento fornecedor↔produto ───
// Alimentado no recebimento (GoodsReceipt) e na importação de NFe.
// Base para: menor preço já pago, preço médio, economia potencial.
model SupplierProductPriceHistory {
  id             String      @id @default(cuid())
  organizationId String
  mappingId      String
  unitCost       Decimal     @db.Decimal(10, 4)
  source         PriceSource @default(MANUAL)
  sourceId       String? // id do GoodsReceipt / NfeImport / PurchaseOrder que originou
  recordedAt     DateTime    @default(now())

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mapping      SupplierProductMapping @relation(fields: [mappingId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([mappingId, recordedAt])
}

enum PriceSource {
  PURCHASE_ORDER
  GOODS_RECEIPT
  NFE_IMPORT
  MANUAL
}

// ── Pedido de compra — espelha Order (RN-P01) ────────────────────────

model PurchaseOrder {
  id             String @id @default(cuid())
  organizationId String
  supplierId     String
  locationId     String

  status PurchaseOrderStatus @default(DRAFT)
  number Int?

  paymentTerms  Json?
  expectedDate  DateTime?
  confirmedDate DateTime?
  notes         String?

  subtotal      Decimal @default(0) @db.Decimal(10, 2)
  discountTotal Decimal @default(0) @db.Decimal(10, 2)
  freight       Decimal @default(0) @db.Decimal(10, 2)
  total         Decimal @default(0) @db.Decimal(10, 2)

  originSuggestionId String?
  originQuotationId  String?
  idempotencyKey     String?
  createdBy          String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization     Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier         Supplier                     @relation(fields: [supplierId], references: [id])
  location         Location                     @relation(fields: [locationId], references: [id])
  items            PurchaseOrderItem[]
  history          PurchaseOrderStatusHistory[]
  receipts         GoodsReceipt[]
  accountPayables  AccountPayable[]
  originSuggestion PurchaseSuggestion?          @relation(fields: [originSuggestionId], references: [id], onDelete: SetNull)
  originQuotation  Quotation?                   @relation(fields: [originQuotationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([supplierId])
  @@index([createdAt])
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  productId       String
  variantId       String?

  productNameSnapshot  String
  expectedQuantity     Decimal  @db.Decimal(10, 3)
  unitCost             Decimal  @db.Decimal(10, 4)
  lineTotal            Decimal  @db.Decimal(10, 2)
  fiscalDataSnapshot   Json?
  expectedPackQuantity Decimal? @db.Decimal(10, 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrder PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product            @relation(fields: [productId], references: [id])
  variant       ProductVariant?    @relation(fields: [variantId], references: [id], onDelete: SetNull)
  receiptItems  GoodsReceiptItem[]

  @@index([purchaseOrderId])
  @@index([productId])
}

model PurchaseOrderStatusHistory {
  id              String               @id @default(cuid())
  purchaseOrderId String
  fromStatus      PurchaseOrderStatus?
  toStatus        PurchaseOrderStatus
  actorId         String?
  source          PoHistorySource      @default(INTERNAL)
  reason          String?
  createdAt       DateTime             @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

// ── Recebimento de mercadoria (RN-P03) ────────────────────────────────

model GoodsReceipt {
  id              String   @id @default(cuid())
  organizationId  String
  purchaseOrderId String
  receivedAt      DateTime @default(now())
  receivedBy      String

  supplierInvoiceNumber    String?
  supplierInvoiceSeries    String?
  supplierInvoiceAccessKey String?

  status            GoodsReceiptStatus @default(DRAFT)
  notes             String?
  divergenceSummary Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchaseOrder   PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  items           GoodsReceiptItem[]
  supplierReturns SupplierReturn[]
  accountPayables AccountPayable[]
  nfeImports      NfeImport[]

  @@index([organizationId])
  @@index([purchaseOrderId])
  @@index([supplierInvoiceAccessKey])
}

model GoodsReceiptItem {
  id                  String  @id @default(cuid())
  goodsReceiptId      String
  purchaseOrderItemId String?

  productId  String
  variantId  String?
  lotCode    String?
  expiryDate DateTime?

  receivedQuantity Decimal        @db.Decimal(10, 3)
  unitCost         Decimal        @db.Decimal(10, 4)
  divergence       DivergenceType @default(NONE)
  divergenceNote   String?

  stockMovementId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goodsReceipt        GoodsReceipt         @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  purchaseOrderItem   PurchaseOrderItem?   @relation(fields: [purchaseOrderItemId], references: [id], onDelete: SetNull)
  product             Product              @relation(fields: [productId], references: [id])
  variant             ProductVariant?      @relation(fields: [variantId], references: [id], onDelete: SetNull)
  supplierReturnItems SupplierReturnItem[]

  @@index([goodsReceiptId])
  @@index([productId])
}

// ── Devolução ao fornecedor (RN-P09) ──────────────────────────────────

model SupplierReturn {
  id             String @id @default(cuid())
  organizationId String
  goodsReceiptId String
  supplierId     String

  reason     SupplierReturnReason
  status     SupplierReturnStatus @default(DRAFT)
  returnedAt DateTime?
  returnedBy String?
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  goodsReceipt GoodsReceipt         @relation(fields: [goodsReceiptId], references: [id])
  supplier     Supplier             @relation(fields: [supplierId], references: [id])
  items        SupplierReturnItem[]

  @@index([organizationId])
  @@index([goodsReceiptId])
}

model SupplierReturnItem {
  id                 String @id @default(cuid())
  supplierReturnId   String
  goodsReceiptItemId String

  quantity Decimal @db.Decimal(10, 3)
  unitCost Decimal @db.Decimal(10, 4)

  stockMovementId            String?
  accountPayableAdjustmentId String?

  supplierReturn   SupplierReturn   @relation(fields: [supplierReturnId], references: [id], onDelete: Cascade)
  goodsReceiptItem GoodsReceiptItem @relation(fields: [goodsReceiptItemId], references: [id])

  @@index([supplierReturnId])
}

// ── Contas a pagar — cabeçalho (RN-P06; Etapa 7 expande) ─────────────

model AccountPayable {
  id              String  @id @default(cuid())
  organizationId  String
  supplierId      String
  goodsReceiptId  String?
  purchaseOrderId String?

  amount     Decimal              @db.Decimal(10, 2)
  paidAmount Decimal              @default(0) @db.Decimal(10, 2)
  dueDate    DateTime
  status     AccountPayableStatus @default(PENDING)

  description       String
  installmentNumber Int     @default(1)
  totalInstallments Int     @default(1)
  categoryId        String?

  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  organization  Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier      Supplier         @relation(fields: [supplierId], references: [id])
  goodsReceipt  GoodsReceipt?    @relation(fields: [goodsReceiptId], references: [id], onDelete: SetNull)
  purchaseOrder PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  category      FinanceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([dueDate])
  @@index([supplierId])
  @@index([categoryId])
}

// ── Contas a receber (Financeiro) ──────────────────────────────────────

enum AccountReceivableStatus {
  PENDING
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELED
}

model AccountReceivable {
  id             String  @id @default(cuid())
  organizationId String
  customerId     String?
  orderId        String?

  amount         Decimal                 @db.Decimal(10, 2)
  receivedAmount Decimal                 @default(0) @db.Decimal(10, 2)
  dueDate        DateTime
  status         AccountReceivableStatus @default(PENDING)

  description       String
  installmentNumber Int     @default(1)
  totalInstallments Int     @default(1)
  categoryId        String?

  receivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  order        Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  category     FinanceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([dueDate])
  @@index([customerId])
  @@index([categoryId])
}

// ── Conciliação de cartão — liquidação D+N (Financeiro) ────────────────

enum SettlementStatus {
  PENDING
  SETTLED
  CANCELED
}

model PaymentSettlement {
  id             String @id @default(cuid())
  organizationId String
  paymentId      String @unique

  provider     String?
  grossAmount  Decimal          @db.Decimal(10, 2)
  feeAmount    Decimal          @db.Decimal(10, 2)
  netAmount    Decimal          @db.Decimal(10, 2)
  expectedDate DateTime
  settledAt    DateTime?
  status       SettlementStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payment      Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([expectedDate])
}

// ── Categorias financeiras — DRE simplificado ──────────────────────────

enum FinanceCategoryKind {
  INCOME
  EXPENSE
}

model FinanceCategory {
  id             String              @id @default(cuid())
  organizationId String
  name           String
  kind           FinanceCategoryKind
  archived       Boolean             @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payables     AccountPayable[]
  receivables  AccountReceivable[]
  movements    CashMovement[]

  @@unique([organizationId, name, kind])
  @@index([organizationId])
}

// ── Cotação (opcional — RN-P11) ────────────────────────────────────────

model Quotation {
  id                   String          @id @default(cuid())
  organizationId       String
  description          String
  status               QuotationStatus @default(OPEN)
  expectedDeliveryDate DateTime?
  createdBy            String
  closedAt             DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization      Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items             QuotationItem[]
  supplierResponses QuotationSupplierResponse[]
  purchaseOrders    PurchaseOrder[]

  @@index([organizationId])
  @@index([organizationId, status])
}

model QuotationItem {
  id          String  @id @default(cuid())
  quotationId String
  productId   String
  variantId   String?
  quantity    Decimal @db.Decimal(10, 3)
  notes       String?

  quotation     Quotation                       @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product       Product                         @relation(fields: [productId], references: [id])
  variant       ProductVariant?                 @relation(fields: [variantId], references: [id], onDelete: SetNull)
  itemResponses QuotationSupplierItemResponse[]

  @@index([quotationId])
}

model QuotationSupplierResponse {
  id          String @id @default(cuid())
  quotationId String
  supplierId  String

  totalPrice   Decimal?  @db.Decimal(10, 2)
  paymentTerms Json?
  leadTimeDays Int?
  notes        String?
  receivedAt   DateTime?
  selected     Boolean   @default(false)

  quotation     Quotation                       @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  supplier      Supplier                        @relation(fields: [supplierId], references: [id])
  itemResponses QuotationSupplierItemResponse[]

  @@index([quotationId])
}

model QuotationSupplierItemResponse {
  id                          String @id @default(cuid())
  quotationSupplierResponseId String
  quotationItemId             String

  unitCost  Decimal? @db.Decimal(10, 4)
  available Boolean  @default(true)
  notes     String?

  response      QuotationSupplierResponse @relation(fields: [quotationSupplierResponseId], references: [id], onDelete: Cascade)
  quotationItem QuotationItem             @relation(fields: [quotationItemId], references: [id], onDelete: Cascade)

  @@index([quotationSupplierResponseId])
}

// ── Sugestão de compra (RN-P13) ───────────────────────────────────────

model PurchaseSuggestion {
  id               String                   @id @default(cuid())
  organizationId   String
  locationId       String
  generatedAt      DateTime                 @default(now())
  status           PurchaseSuggestionStatus @default(PENDING)
  algorithmVersion String                   @default("v1")
  reasonSummary    Json?

  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location       Location                 @relation(fields: [locationId], references: [id])
  items          PurchaseSuggestionItem[]
  purchaseOrders PurchaseOrder[]

  @@index([organizationId])
  @@index([locationId])
}

model PurchaseSuggestionItem {
  id                   String  @id @default(cuid())
  purchaseSuggestionId String
  productId            String
  variantId            String?

  suggestedQuantity   Decimal  @db.Decimal(10, 3)
  currentStock        Decimal  @db.Decimal(10, 3)
  averageDailySales   Decimal? @db.Decimal(10, 4)
  daysOfCoverage      Decimal? @db.Decimal(10, 2)
  suggestedSupplierId String?

  suggestion PurchaseSuggestion @relation(fields: [purchaseSuggestionId], references: [id], onDelete: Cascade)
  product    Product            @relation(fields: [productId], references: [id])
  variant    ProductVariant?    @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([purchaseSuggestionId])
}

// ── Importação de NFe de entrada (RN-P10, RN-P11, RN-P15) ────────────

model NfeImport {
  id             String          @id @default(cuid())
  organizationId String
  accessKey      String          @unique
  xmlContent     String          @db.Text
  status         NfeImportStatus @default(PENDING)
  uploadedBy     String
  uploadedAt     DateTime        @default(now())

  supplierId      String?
  purchaseOrderId String?
  goodsReceiptId  String?

  parseErrors    Json?
  parsedData     Json?
  mappingPending Json?

  updatedAt DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  goodsReceipt GoodsReceipt? @relation(fields: [goodsReceiptId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, status])
}

// ── Tags de produto — biblioteca por organização (RN-T01) ────────────────

enum TagScope {
  SUBCATEGORY // tag contextual — caracteriza uma subcategoria (gelado, vegano, artesanal)
  PRODUCT // atributo de SKU — específico do produto (350ml, lata, long-neck)
}

model Tag {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String
  group          String   @default("geral")
  color          String?
  description    String?
  scope          TagScope @default(PRODUCT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     ProductTag[]
  categories   CategoryTag[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([organizationId, group])
}

model ProductTag {
  productId  String
  tagId      String
  assignedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@index([productId])
  @@index([tagId])
}

model CategoryTag {
  categoryId String
  tagId      String

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([categoryId, tagId])
  @@index([categoryId])
  @@index([tagId])
}
