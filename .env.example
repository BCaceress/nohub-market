# ── Database (Neon - https://neon.tech) ─────────────────────────────
DATABASE_URL=                 # connection pooled (runtime)
DIRECT_DATABASE_URL=          # connection direta (migrations)

# ── Better Auth ─────────────────────────────────────────────────────
BETTER_AUTH_SECRET=           # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000

# ── Google OAuth (Google Cloud Console) ─────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Resend (emails transacionais) ───────────────────────────────────
RESEND_API_KEY=               # re_xxx
EMAIL_FROM="NoHub Market <noreply@seu-dominio.com.br>"

# ── APIs externas (Brasil) ──────────────────────────────────────────
BRASILAPI_URL=https://brasilapi.com.br/api

# ── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="NoHub Market"
